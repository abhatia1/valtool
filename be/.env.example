# Application Configuration
APP_NAME=Valtool AutoML
APP_VERSION=1.0.0
DEBUG=True

# API Settings
API_V1_PREFIX=/api

# Database Configuration
# For SQLite (development)
DATABASE_URL=sqlite:///./valtool.db

# For PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost:5432/valtool

# Storage Paths
BASE_STORAGE_PATH=./storage
DATASETS_PATH=./storage/datasets
MODELS_PATH=./storage/models
ARTIFACTS_PATH=./storage/artifacts
MLRUNS_PATH=./storage/mlruns

# File Upload Settings
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=[".csv"]

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ENABLED=False

# Training Configuration
DEFAULT_CV_FOLDS=5
DEFAULT_N_JOBS=-1
TRAINING_TIMEOUT=3600

# Monitoring Configuration
DRIFT_THRESHOLD=0.05
